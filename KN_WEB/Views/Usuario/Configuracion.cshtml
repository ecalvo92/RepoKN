@model KN_WEB.Models.UsuarioModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var nombreUsuario = HttpContext.Current.Session["NombreUsuario"] ?? string.Empty;
    var nombreRol = HttpContext.Current.Session["NombreRol"] ?? string.Empty;
}

<div class="row">

    <div class="col-12 col-lg-5 mx-auto">
        <div class="card bg-transparent">
            <div class="card-body">
                <div class="d-flex justify-content-center align-items-center flex-column">
                    <div class="avatar avatar-2xl">
                        <img src="~/Content/images/security.png" alt="Security">
                    </div>

                    <h4 class="mt-3">@nombreUsuario</h4>
                    <h6>Rol en el sistema: @nombreRol</h6>
                </div>
            </div>
        </div>
    </div>

</div>


<div class="row">

    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">

                @using (Html.BeginForm("CambiarContrasenna", "Usuario", FormMethod.Post, new { @id = "CambiarContrasennaForm" }))
                {

                    if (ViewBag.MensajeSeguridad != null)
                    {
                        <div class="alert text-danger" role="alert">
                            @ViewBag.MensajeSeguridad
                        </div>
                    }

                    <div class="form-group">
                        <label for="Contrasenna" class="form-label">Contraseña Nueva</label>
                        @Html.TextBoxFor(m => m.Contrasenna, new { @type = "password", @class = "form-control form-control-xl", @placeholder = "Contraseña" })
                    </div>

                    <div class="form-group">
                        <label for="Contrasenna" class="form-label">Confirmar Contraseña</label>
                        @Html.TextBoxFor(m => m.ConfirmarContrasenna, new { @type = "password", @class = "form-control form-control-xl", @placeholder = "Contraseña" })
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Procesar</button>
                    </div>
                }

            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">

                @using (Html.BeginForm("CambiarPerfil", "Usuario", FormMethod.Post, new { @id = "CambiarPerfilForm" }))
                {

                    if (ViewBag.MensajePerfil != null)
                    {
                        <div class="alert text-danger" role="alert">
                            @ViewBag.MensajePerfil
                        </div>
                    }

                    <div class="form-group">
                        <label for="Nombre" class="form-label">Nombre</label>
                        @Html.TextBoxFor(m => m.Nombre, new {@class = "form-control form-control-xl" })
                    </div>

                    <div class="form-group">
                        <label for="CorreoElectronico" class="form-label">Correo Electrónico</label>
                        @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control form-control-xl" })
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Procesar</button>
                    </div>
                }

            </div>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/Scripts/configuracion.js"></script>
}