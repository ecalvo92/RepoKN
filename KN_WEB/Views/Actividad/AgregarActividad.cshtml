@model KN_WEB.EF.tbActividad

@using (Html.BeginForm("AgregarActividad", "Actividad", FormMethod.Post, new { @id = "AgregarActividadForm", @enctype = "multipart/form-data" }))
{
    <div class="row">

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-body">

                    <h4 class="card-title mb-0">Nueva Actividad</h4>

                    @if (ViewBag.MensajeSeguridad != null)
                    {
                        <div class="alert text-danger" role="alert">
                            @ViewBag.MensajeSeguridad
                        </div>
                    }

                    <div class="form-group">
                        <label for="Titulo" class="form-label">Título</label>
                        @Html.TextBoxFor(m => m.Titulo, new { @type = "text", @class = "form-control form-control-xl" })
                    </div>

                    <div class="form-group">
                        <label for="Inicio" class="form-label">Inicio</label>
                        @Html.TextBoxFor(m => m.Inicio, new { type = "datetime-local", @class = "form-control form-control-xl", onkeydown = "return false" })
                    </div>

                    <div class="form-group">
                        <label for="Fin" class="form-label">Finalización</label>
                        @Html.TextBoxFor(m => m.Fin, new { type = "datetime-local", @class = "form-control form-control-xl", onkeydown = "return false" })
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Procesar</button>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-body">

                    <h5 class="card-title mb-3">Imagen de la actividad</h5>

                    <div id="zonaImagen" class="zona-imagen d-flex flex-column align-items-center justify-content-center"
                         onclick="document.getElementById('inputImagen').click()">
                        <span id="textoImagen" class="text-muted mt-2">Haga clic para seleccionar una imagen</span>
                        <img id="previstaImagen" src="#" alt="Vista previa" class="previa-imagen d-none" />
                    </div>

                    <input type="file" id="inputImagen" name="Imagen" accept="image/*" class="d-none"
                           onchange="previsualizarImagen(this)" />

                </div>
            </div>
        </div>

    </div>
}

@section scripts {
    <script src="~/Scripts/agregarActividad.js"></script>
}