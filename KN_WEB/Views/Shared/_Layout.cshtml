    @{
        var nombreUsuario = HttpContext.Current.Session["NombreUsuario"].ToString() ?? string.Empty;
        var nombreRol = HttpContext.Current.Session["NombreRol"].ToString() ?? string.Empty;
        var consecutivoRol = HttpContext.Current.Session["ConsecutivoRol"].ToString() ?? string.Empty;
    }

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proyecto Web - KN</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/bootstrap.css">
    <link rel="stylesheet" href="~/Content/perfect-scrollbar.css">
    <link rel="stylesheet" href="~/Content/bootstrap-icons.css">
    <link rel="stylesheet" href="~/Content/app.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.4/css/dataTables.bootstrap5.css">
</head>

<body>
    <div id="app">
        <div id="sidebar" class="active">
            <div class="sidebar-wrapper active">
                <div class="sidebar-header">
                    <div class="d-flex justify-content-between">
                        <div class="logo">
                            <a href="@Url.Action("Principal","Home")"><img src="~/Content/images/logo.png" alt="Logo" srcset=""></a>
                        </div>
                        <div class="toggler">
                            <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                        </div>
                    </div>
                </div>
                <div class="sidebar-menu">
                    <ul class="menu">

                        @if (consecutivoRol == "2")
                        {
                            <li class="sidebar-item active">
                                <a href="@Url.Action("VerActividades", "Actividad")" class='sidebar-link'>
                                    <i class="bi bi-file-earmark-medical-fill"></i>
                                    <span>Ver Actividades</span>
                                </a>
                            </li>
                        }



                    </ul>
                </div>
                <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
            </div>
        </div>
        <div id="main">
            <header class="mb-3">
                <nav class="navbar navbar-expand navbar-header">
                    <a href="#" class="burger-btn d-block d-xl-none">
                        <i class="bi bi-justify fs-3"></i>
                    </a>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-menu d-flex align-items-center" href="#" id="userDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="avatar bg-primary me-2">
                                        <div class="avatar-content">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                    </div>
                                    <div class="d-none d-sm-block text-start lh-sm">
                                        <span class="d-block fw-semibold" style="color: inherit;"> @nombreUsuario </span>
                                        <span class="d-block" style="font-size: 0.80rem; color: #6c757d; letter-spacing: 0.03em;">@nombreRol</span>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">

                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Configuracion", "Usuario")">
                                            <i class="bi bi-shield-lock me-2"></i>Configuración
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item text-danger" href="@Url.Action("CerrarSesion", "Home")">
                                            <i class="bi bi-box-arrow-left me-2"></i>Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
            </header>

            <div class="page-heading">

                @RenderBody()

            </div>

            <footer>
                <div class="footer clearfix mb-0 text-muted">
                    <div class="float-start">
                        <p>@DateTime.Now.Year &copy; Mazer</p>
                    </div>
                    <div class="float-end">
                        <p>
                            Proyecto Web - KN
                        </p>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="~/Scripts/perfect-scrollbar.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/main.js"></script>
    <script src="https://cdn.datatables.net/2.3.4/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.4/js/dataTables.bootstrap5.js"></script>

    @RenderSection("scripts", required: false)
</body>

</html>